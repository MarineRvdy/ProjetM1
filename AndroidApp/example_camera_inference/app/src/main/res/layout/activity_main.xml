<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"/>

    <!-- Bounding Box Overlay (Hidden by Default) -->
    <com.example.test_camera.BoundingBoxOverlay
        android:id="@+id/boundingBoxOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:visibility="gone"/>

    <!-- Top Bar with Logo, Title and Control Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="@android:color/white"
        android:elevation="20dp"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- School Logo -->
        <ImageView
            android:id="@+id/schoolLogoImageView"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/school_logo"
            android:scaleType="fitCenter"
            android:contentDescription="Logo de l'école"/>

        <!-- Title (centered) -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Détection Triviidae"
            android:textColor="@android:color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <!-- Sound Toggle Button -->
        <ImageView
            android:id="@+id/soundToggleButton"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/ic_sound_on"
            android:scaleType="fitCenter"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Activer/Désactiver le son"
            android:layout_marginEnd="8dp"/>

        <!-- Vibration Toggle Button -->
        <ImageView
            android:id="@+id/vibrationToggleButton"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/ic_vibration_on"
            android:scaleType="fitCenter"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Activer/Désactiver la vibration"
            android:layout_marginEnd="8dp"/>

        <!-- Flash Toggle Button -->
        <ImageView
            android:id="@+id/flashToggleButton"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/ic_flash_off"
            android:scaleType="fitCenter"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Activer/Désactiver le flash"/>

    </LinearLayout>

    <!-- Result Display Frame -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:orientation="vertical"
        android:background="@android:color/holo_blue_light"
        android:gravity="center"
        android:elevation="15dp"
        android:layout_gravity="bottom">

        <TextView
            android:id="@+id/detectionCounterTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Détections: 0"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="4dp"/>

            </LinearLayout>

    <!-- Validation Buttons (Hidden by Default) -->
    <LinearLayout
        android:id="@+id/validationButtonsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="16dp"
        android:background="@android:color/background_dark"
        android:visibility="gone"
        android:elevation="10dp"
        android:layout_marginBottom="80dp">

        <Button
            android:id="@+id/yesButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Yes"
            android:textSize="16sp"
            android:background="@android:color/holo_green_dark"
            android:textColor="@android:color/white"
            android:padding="12dp"/>

        <Button
            android:id="@+id/noButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:text="No"
            android:textSize="16sp"
            android:background="@android:color/holo_orange_dark"
            android:textColor="@android:color/white"
            android:padding="12dp"/>

        <Button
            android:id="@+id/trashButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Trash"
            android:textSize="16sp"
            android:background="@android:color/holo_red_dark"
            android:textColor="@android:color/white"
            android:padding="12dp"/>

    </LinearLayout>

    <!-- Frozen Image Display (Hidden by Default) -->
    <ImageView
        android:id="@+id/frozenImageView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:visibility="gone"
        android:elevation="5dp"/>

    <!-- Capture Photo Button -->
    <Button
        android:id="@+id/captureButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center|bottom"
        android:layout_marginBottom="80dp"
        android:text="Capturer"
        android:textSize="16sp"
        android:background="@android:color/holo_blue_bright"
        android:textColor="@android:color/white"
        android:padding="12dp"
        android:elevation="8dp"/>

</FrameLayout>
